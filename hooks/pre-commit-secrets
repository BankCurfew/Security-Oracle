#!/usr/bin/env bash
# pre-commit-secrets — Block commits containing secrets
# Install: cp to .git/hooks/pre-commit (or symlink)
# By Security-Oracle — BoB's Office

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Patterns that indicate secrets (case-insensitive grep -iE)
SECRET_PATTERNS='(SUPABASE_SERVICE_ROLE_KEY|SUPABASE_KEY|API_KEY|SECRET_KEY|PRIVATE_KEY|PASSWORD\s*=|TOKEN\s*=|Bearer\s+ey|sk-[a-zA-Z0-9]{20,}|eyJ[a-zA-Z0-9_-]{30,}|-----BEGIN\s+(RSA\s+)?PRIVATE\s+KEY)'

# Files to always block
BLOCKED_FILES='(\.env$|\.env\.[^e]|credentials\.json|secrets\.json|\.pem$|\.key$|id_rsa)'

STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)

if [ -z "$STAGED" ]; then
  exit 0
fi

FOUND=0

# Check for blocked file types
while IFS= read -r file; do
  if echo "$file" | grep -qiE "$BLOCKED_FILES"; then
    echo -e "${RED}🔴 BLOCKED${NC}: $file — sensitive file type"
    FOUND=1
  fi
done <<< "$STAGED"

# Check staged content for secret patterns
while IFS= read -r file; do
  # Skip binary files, hook scripts, and audit reports
  if ! git show ":$file" 2>/dev/null | file - | grep -q text; then
    continue
  fi
  if echo "$file" | grep -qE '(hooks/|pre-commit|audits/|AUDIT)'; then
    continue
  fi

  MATCHES=$(git show ":$file" 2>/dev/null | grep -inE "$SECRET_PATTERNS" || true)
  if [ -n "$MATCHES" ]; then
    echo -e "${RED}🔴 SECRET DETECTED${NC} in ${YELLOW}$file${NC}:"
    echo "$MATCHES" | head -5
    FOUND=1
  fi
done <<< "$STAGED"

if [ "$FOUND" -ne 0 ]; then
  echo ""
  echo -e "${RED}❌ Commit blocked by Security-Oracle pre-commit hook${NC}"
  echo "   Remove secrets or add files to .gitignore"
  echo "   Override (NOT recommended): git commit --no-verify"
  exit 1
fi

exit 0
